# Copy to gradle.properties (gitignored) or pass -P flags / environment variables.
# See README for EAPI_* environment variable names.

# Either set e2e.eapi.baseUrl OR use a named profile from src/main/resources/e2e/environments.json
e2e.envProfile=qa-eapi-dev
e2e.eapi.baseUrl=
# Optional: only set if you want Gradle to override E2E_CLUB_NUMBER from the shell/CI.
# Leave unset so GitHub Actions can drive the club via the workflow input (E2E_CLUB_NUMBER).
# e2e.clubNumber=06060
e2e.paymentPlanName=INSTALLMENT
# Optional: absolute path to a custom clubs.json (same schema as resources/e2e/clubs.json)
# e2e.clubsJsonPath=
# Optional: fail if club is not listed in clubs.json
# e2e.requireClubInCatalog=false

# Optional: multi-agreement / sharding (GitHub Actions matrix sets these automatically)
# e2e.totalAgreements=20
# e2e.shardCount=20
# e2e.shardIndex=0
